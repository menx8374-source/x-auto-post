# Anthropic API(Claude)のAPIキー。F3(投稿文面生成)で使用する。
# https://console.anthropic.com/ でアカウントを作成し発行する(従量課金)。
# 未設定の場合、文面生成はエラーとして安全に終了する(投稿処理には進まない)。
ANTHROPIC_API_KEY=

# (任意)使用するClaudeモデルID。未設定時はコード側のデフォルト(claude-haiku-4-5-20251001)を使う。
ANTHROPIC_MODEL=

# X API v2の認証情報(F6: 実際にXへツイートを投稿する場合に使用)。
# https://developer.x.com/ でアプリを作成し発行する。Access Tokenは「Read and Write」権限が必要。
# いずれか未設定の場合、投稿処理はAPIを呼び出さず安全にエラーとして終了する(ドライラン等には影響しない)。
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# (任意)F9: 不発リカバリの許容範囲(時間)。未設定時は既定値(3時間)を使う。
POST_RECOVERY_WINDOW_HOURS=

# ---- F12: 運用パラメータ(挙動系設定。認証情報ではないため公開しても機密性は無いが、.envで一元管理する) ----

# (任意)投稿枠(朝/昼/夜)の目安時刻(JST、"HH:MM"形式)。未設定時は既定値(07:30/12:15/21:00)を使う。
POST_SLOT_MORNING_TIME=
POST_SLOT_NOON_TIME=
POST_SLOT_EVENING_TIME=

# (任意)F3: 生成する投稿文面の言語("ja"等)・トーン(自由文)。未設定時はコード側の既定値を使う。
POST_LANGUAGE=
POST_TONE=

# (任意)F4: 1スレッドに含める本文ツイートの上限本数(1以上の整数)。未設定時は既定値(6)を使う。
POST_MAX_BODY_TWEETS=

# (任意)F5: リンクツイートの有無("true"/"false")・位置("start"/"end")。未設定時は既定値(true/end)を使う。
POST_LINK_TWEET_ENABLED=
POST_LINK_TWEET_POSITION=

# (任意)F10: 投稿失敗・投稿対象なし・不発リカバリの許容範囲超過時に追加で通知するWebhook URL
# (Slack incoming webhook等、JSON POSTを受け付ける任意のエンドポイント)。未設定時は実行ログのみに残る。
NOTIFY_WEBHOOK_URL=

# ---- アフィリエイト投稿(AIニュース3枠とは独立したパイプライン、任意) ----

# (任意)アフィリエイト投稿枠の目安時刻(JST、"HH:MM"形式)。未設定時は既定値(19:00)を使う。
AFFILIATE_POST_TIME=

# (任意)同一商品の投稿回数の上限(ローテーション、1以上の整数)。未設定時は既定値(3)を使う。
AFFILIATE_MAX_POSTS_PER_PRODUCT=

# ---- 複数Xアカウント対応(任意) ----
# デフォルトアカウント("ai-news")は上記のサフィックス無し変数(ANTHROPIC_API_KEY/X_API_KEY等)を
# そのまま使う。新規アカウントをsrc/accounts.tsに追加した場合のみ、そのAccountProfileの
# credentialsEnvSuffixに対応する `<変数名>__<SUFFIX>` という名前の変数を追加する
# (例: ANTHROPIC_API_KEY__GENRE2 / X_API_KEY__GENRE2 等)。詳細はREADME.md「複数Xアカウント対応(基盤)」参照。
