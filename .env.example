# Anthropic API(Claude)のAPIキー。F3(投稿文面生成)で使用する。
# https://console.anthropic.com/ でアカウントを作成し発行する(従量課金)。
# 未設定の場合、文面生成はエラーとして安全に終了する(投稿処理には進まない)。
ANTHROPIC_API_KEY=

# (任意)使用するClaudeモデルID。未設定時はコード側のデフォルト(claude-3-5-haiku-20241022)を使う。
ANTHROPIC_MODEL=

# X API v2の認証情報(F6: 実際にXへツイートを投稿する場合に使用)。
# https://developer.x.com/ でアプリを作成し発行する。Access Tokenは「Read and Write」権限が必要。
# いずれか未設定の場合、投稿処理はAPIを呼び出さず安全にエラーとして終了する(ドライラン等には影響しない)。
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# (任意)F9: 不発リカバリの許容範囲(時間)。未設定時は既定値(3時間)を使う。
POST_RECOVERY_WINDOW_HOURS=
