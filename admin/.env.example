# アフィリエイト商品管理ページ(admin/)のローカル開発用環境変数一覧。
# 値はすべてダミー。実際の値は絶対にコミットしないこと。
#
# ローカルで `npm run dev`(wrangler pages dev)を動かす場合は、このファイルを
# `.dev.vars` という名前でコピーして値を埋める(`.dev.vars` はgitignore対象、
# wrangler pages dev が自動的に読み込む)。
#
# 本番(Cloudflare Pages)では、Cloudflareダッシュボードの Pages プロジェクト設定
# > Environment variables にユーザー本人が同じキー名で登録する(このリポジトリの
# セットアップ対象外)。

# GitHubパーソナルアクセストークン(Fine-grained推奨)。対象リポジトリへの
# Contents(読み書き)・Actions(workflow_dispatch起動)権限が必要。
GITHUB_PAT=

# 対象リポジトリ("owner/repo"形式)
GITHUB_REPO=menx8374-source/x-auto-post

# 商品データ・ワークフロー起動の対象ブランチ
GITHUB_BRANCH=main

# GitHub OAuth App(ユーザー本人ログイン用)のクライアントID・シークレット。
# https://github.com/settings/developers で登録する(Authorization callback URLは
# `https://<pages-domain>/api/auth/callback` またはローカル開発では
# `http://127.0.0.1:8788/api/auth/callback`)。
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ログインを許可する唯一のGitHubユーザー名(大小無視で厳密一致するアカウントのみ許可)
ALLOWED_GITHUB_LOGIN=

# セッションCookie署名用のシークレット(十分にランダムな長い文字列。例: openssl rand -hex 32)
SESSION_SECRET=
