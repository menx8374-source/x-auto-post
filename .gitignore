# Secrets — never commit real credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
token.json
*.token

# Dependencies
node_modules/
__pycache__/
.venv/
venv/

# Build output
dist/
build/
.next/
out/

# Local databases (runtime data, not source)
*.sqlite
*.sqlite3
*.db

# Runtime output (regenerated each run, not source)
data/output/

# Runtime state (post selection/posting history)
# Sprint 9: post-history.json IS committed to git. GitHub Actions runs on ephemeral checkouts,
# so cross-run idempotency (1 slot/day) and existing-article dedup require the history file to be
# persisted in the repo itself (the workflow commits+pushes it after each run). Any other file that
# might land under data/history/ stays ignored.
data/history/*
!data/history/post-history.json
# アフィリエイト投稿専用の投稿履歴(ローテーション・冪等性判定用)。GitHub Actions実行後にワークフローが
# コミットして永続化するため、post-history.json同様git管理対象にする。
!data/history/affiliate-post-history.json

# A8.net提携申請ステータス追跡(admin管理ページがGitHub Contents API経由でコミットして永続化するデータ。
# 上記2ファイルと同じ理由)。
!data/affiliate-application-tracking.json

# admin/(Cloudflare Pages)サブプロジェクトのローカル開発用シークレット・wrangler実行時状態。
# admin/node_modules/ は上記 node_modules/ パターンで既にカバーされる。
admin/.dev.vars
admin/.dev.vars.*
admin/.wrangler/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db

# spec-pipeline: 実行時ダッシュボード状態(スプリント成果物ではない。docs/dashboard.htmlは静的なので追跡対象)
docs/pipeline-status.js

# spec-pipeline: Playwright MCPのスクラッチ出力(evaluatorがプレビュー画像をdocs/sprints/へコピーした後の残骸)
.playwright-mcp/
