{
  "name": "xautomode",
  "version": "1.0.0",
  "description": "X(旧Twitter)向けAIニュース自動投稿バックエンド。急上昇AIニュースの収集・スコアリング・投稿を自動化する。",
  "private": true,
  "type": "module",
  "scripts": {
    "collect": "tsx src/collectNews.ts",
    "select": "tsx src/selectPost.ts",
    "generate": "tsx src/generatePost.ts",
    "thread": "tsx src/buildThread.ts",
    "dryrun": "tsx src/dryRun.ts",
    "post": "tsx src/publish.ts",
    "dryrun:affiliate": "tsx src/dryRunAffiliate.ts",
    "post:affiliate": "tsx src/publishAffiliate.ts",
    "generate:affiliate-redirects": "tsx src/generateAffiliateRedirects.ts",
    "admin:delete-tweet": "tsx src/adminTweetTool.ts delete-tweet",
    "admin:test-post": "tsx src/adminTweetTool.ts test-post",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "rss-parser": "^3.13.0",
    "twitter-api-v2": "^1.29.0",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
